
 
#include "p42.dtsi"



&kscan0 {
    diode-direction = "col2row";
    col-gpios
        = <&gpio0 15 GPIO_ACTIVE_HIGH>
        , <&gpio0 31 GPIO_ACTIVE_HIGH>
        , <&gpio0 30 GPIO_ACTIVE_HIGH>
        , <&gpio0 29 GPIO_ACTIVE_HIGH>
        ;

      row-gpios = <
        &gpio0 20 (GPIO_PULL_DOWN | GPIO_ACTIVE_HIGH)
        &gpio0 17 (GPIO_PULL_DOWN | GPIO_ACTIVE_HIGH)
        &gpio0 0 (GPIO_PULL_DOWN | GPIO_ACTIVE_HIGH)
        &gpio0 4 (GPIO_PULL_DOWN | GPIO_ACTIVE_HIGH)
        >;
};
/ {
    lfclk: lfclk {
        compatible = "fixed-clock";
        clock-frequency = <32768>;
        #clock-cells = <0>;
        status = "okay";
    };
};


#include <dt-bindings/led/led.h>

&pinctrl {
    spi2_default: spi2_default {
        group1 {
            psels = <
                NRF_PSEL(SPIM_SCK, 0, 6)
                NRF_PSEL(SPIM_MOSI, 0, 5)
            >;
            
        };
    };

    spi2_sleep: spi2_sleep {
        group1 {
             psels = <
                NRF_PSEL(SPIM_SCK, 0, 6)
                NRF_PSEL(SPIM_MOSI, 0, 5)
            >;
            low-power-enable;
        };
    };
};

&spi2 {
    compatible = "nordic,nrf-spim";
    status = "okay";

    pinctrl-0 = <&spi2_default>;
    pinctrl-1 = <&spi2_sleep>;
    pinctrl-names = "default", "sleep";

    led_strip: ws2812@0 {
        compatible = "worldsemi,ws2812-spi";

               reg = <0>; /* ignored, but necessary for SPI bindings */
        spi-max-frequency = <4000000>;

        /* WS2812 */
        chain-length = <42>; /* number of LEDs */
        spi-one-frame = <0x70>;
        spi-zero-frame = <0x40>;
        color-mapping = <LED_COLOR_ID_GREEN
                         LED_COLOR_ID_RED
                         LED_COLOR_ID_BLUE>;
    };
};


/
{
    chosen {
        // zmk,ext-power = &ex2;
        zmk,underglow = &led_strip;
    };

    EXT_POWER {
        compatible = "zmk,ext-power-generic";
        control-gpios = <&gpio0 3 GPIO_ACTIVE_HIGH>;
        init-delay-ms = <50>;
    };
};

/ {
    leds {
        compatible = "gpio-leds";

        led0: led_0 {
            gpios = <&gpio1 9 GPIO_ACTIVE_HIGH>;
        };
        led1: led_1 {
            gpios = <&gpio0 11 GPIO_ACTIVE_HIGH>;
        };
        led2: led_2 {
            gpios = <&gpio0 15 GPIO_ACTIVE_HIGH>;
        };
    };

    aliases {
        led0 = &led0;
        led1 = &led1;
        led2 = &led2;
    };
};



#include "donki36__esb_addr.dtsi"


/ {
    soc {
        pin-controller {
            #binding-cells = <0>;
        };
    };
};